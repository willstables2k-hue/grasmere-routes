# Copy this file to .streamlit/secrets.toml and fill in real values.
# .streamlit/secrets.toml is gitignored.

# --- Database (Supabase Postgres — same Brain as grasmere-sales-dashboard) ---
BRAIN_DB_URL = "postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"

# --- Mapbox token (server-side, used for geocoding + driving matrix) ---
MAPBOX_TOKEN = ""

# --- Auth (Streamlit native OIDC) ---
# https://docs.streamlit.io/develop/concepts/connections/authentication
[auth]
redirect_uri = "https://grasmere-routes.streamlit.app/oauth2callback"
cookie_secret = "generate-a-random-32-char-string"
client_id = "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID"
client_secret = "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[app]
allowed_emails = [
  "willstables.2k@gmail.com",
  # add dispatchers + drivers here
]
# Optional per-user role override; defaults to 'dispatcher' for everyone else
[app.roles]
"willstables.2k@gmail.com" = "admin"
# "driver1@grasmerefarm.co.uk" = "driver"

# --- Depot defaults (only used by the migration seed; not read at runtime) ---
DEPOT_LAT = 52.7691
DEPOT_LNG = -0.3819
DEPOT_NAME = "Grasmere Farm, Bourne"
