# Copy this file to .streamlit/secrets.toml and fill in real values.
# .streamlit/secrets.toml is gitignored.

# --- Database (Supabase Postgres — same Brain as grasmere-sales-dashboard) ---
BRAIN_DB_URL = "postgresql://USER:PASS@HOST:5432/postgres?sslmode=require"

# --- Mapbox token (server-side, used for geocoding + driving matrix) ---
MAPBOX_TOKEN = ""

# --- App access ---
[app]
# Shared team password. Defaults to "grasmere2026" if this is unset, but
# rotate it here once you're ready.
password = "grasmere2026"

# --- Depot defaults (only used by the migration seed; not read at runtime) ---
DEPOT_LAT = 52.7691
DEPOT_LNG = -0.3819
DEPOT_NAME = "Grasmere Farm, Bourne"
